# Base de datos PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/catalog_db"

# API Key que DatiHub enviara en Authorization: Bearer
API_KEY="sk-catalog-mesdessous-xxxxx"

# Entorno
NODE_ENV="development"
PORT=3000

# URL del feed XML de productos (Shopping Feed / export del ecommerce)
# Si no esta definida, el script usara el archivo local scripts/650.ia_agent.xml
BEDROCK_KB_SOURCE_URL="https://export.shopping-feed.com/stream/xxxxxx"
